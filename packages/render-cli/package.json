{
  "name": "@pepperhorn/render-cli",
  "version": "0.1.0",
  "description": "Batch-render keyboard chord SVGs from manifests using @pepperhorn/chordl-react",
  "private": true,
  "type": "module",
  "bin": {
    "chordl-render": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "render": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pepperhorn/chordl-core": "workspace:*",
    "@pepperhorn/chordl-react": "workspace:*",
    "@pepperhorn/chordl-voicings": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
