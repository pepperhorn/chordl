{
  "name": "@pepperhorn/chordl-core",
  "version": "0.3.3",
  "description": "Pure TypeScript chord parsing, resolving, layout, and export engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@pepperhorn/chordl-voicings": "workspace:*",
    "tonal": "^6.3.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
